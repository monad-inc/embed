{
	"name": "@monad-inc/embed-workspace",
	"version": "0.0.0",
	"private": true,
	"license": "Apache-2.0",
	"description": "Workspace root for Monad's public embed SDKs. Tools to embed Monad's UI in other apps using a secure iframe and safe cross-browser comms.",
	"author": "Monad Inc.",
	"homepage": "https://github.com/monad-inc/embed",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/monad-inc/embed.git"
	},
	"bugs": {
		"url": "https://github.com/monad-inc/embed/issues"
	},
	"packageManager": "pnpm@9.15.0",
	"engines": {
		"node": ">=20",
		"pnpm": ">=9"
	},
	"scripts": {
		"build": "pnpm -r run build",
		"typecheck": "pnpm -r run typecheck",
		"test": "pnpm -r run test",
		"lint": "eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "pnpm -r run build && changeset publish"
	},
	"devDependencies": {
		"@changesets/cli": "^2.27.9",
		"@eslint/js": "^9.13.0",
		"eslint": "^9.13.0",
		"prettier": "^3.3.3",
		"typescript": "^5.6.3",
		"typescript-eslint": "^8.11.0"
	}
}
