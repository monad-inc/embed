{
	"name": "@monad-inc/embed",
	"version": "0.1.0",
	"description": "SDK for embedding Monad's UI in other apps via a secure cross-origin iframe. The connect module (createConnectorFrame()) renders the connector-config form inside a Monad-hosted iframe, so the host's JavaScript never sees credential material — only a connector id reference comes back. Zero runtime dependencies.",
	"license": "Apache-2.0",
	"author": "Monad Inc.",
	"homepage": "https://github.com/monad-inc/embed/tree/main/packages/embed",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/monad-inc/embed.git",
		"directory": "packages/embed"
	},
	"bugs": {
		"url": "https://github.com/monad-inc/embed/issues"
	},
	"keywords": [
		"monad",
		"connector",
		"embed",
		"white-label"
	],
	"type": "module",
	"exports": {
		"./connect": {
			"import": {
				"types": "./dist/connect/index.d.ts",
				"default": "./dist/connect/index.js"
			},
			"require": {
				"types": "./dist/connect/index.d.cts",
				"default": "./dist/connect/index.cjs"
			}
		},
		"./package.json": "./package.json"
	},
	"sideEffects": false,
	"files": [
		"dist",
		"README.md",
		"USAGE.md",
		"CHANGELOG.md",
		"LICENSE",
		"NOTICE"
	],
	"engines": {
		"node": ">=18"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"provenance": true
	},
	"scripts": {
		"build": "tsup",
		"build:watch": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"prepublishOnly": "pnpm run typecheck && pnpm run test && pnpm run build"
	},
	"devDependencies": {
		"@types/node": "^22.9.0",
		"jsdom": "^25.0.1",
		"tsup": "^8.3.5",
		"typescript": "^5.6.3",
		"vitest": "^2.1.5"
	}
}
